# ============================================================
# GeminiGen API 服务器配置
# 复制此文件为 .env 并填写实际值
# ============================================================

# ── 安全密钥（必须修改！随机长字符串）────────────────────────
SECRET_KEY=请替换为随机长字符串如:xK9mP2qLvN8wR5tY3uA6bC1dE4fG7hJ0

# ── 数据库 ───────────────────────────────────────────────────
DB_HOST=47.95.157.46
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root@kunkun
DB_NAME=geminigen_platform

# ── 服务端口 ─────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Worker 配置（服务器上不需要，留空即可）───────────────────
# 服务器上的 Worker 已关闭（WORKER_COUNT=0）
# 生成任务由本地电脑的 worker_standalone.py 处理
WORKER_COUNT=0
GEMINIGEN_USERNAME=
GEMINIGEN_PASSWORD=
