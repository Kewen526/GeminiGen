# ============================================================
# GeminiGen API 服务器配置
# 复制此文件为 .env 并填写实际值
# ============================================================

# ── 安全密钥（必须修改！随机长字符串）────────────────────────
SECRET_KEY=请替换为随机长字符串如:xK9mP2qLvN8wR5tY3uA6bC1dE4fG7hJ0

# ── 数据库 ───────────────────────────────────────────────────
DB_HOST=47.95.157.46
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root@kunkun
DB_NAME=geminigen_platform

# ── 服务端口 ─────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── 服务器 Worker（保持 0，服务器不处理生成任务）────────────
WORKER_COUNT=0

# ── 本地 Worker 账号配置 ──────────────────────────────────────
# 方式一：单账号
GEMINIGEN_USERNAME=your_account@gmail.com
GEMINIGEN_PASSWORD=your_password

# 方式二：多账号（注释掉上面两行，启用下面这行）
# 格式: 邮箱:密码,邮箱2:密码2（账号间用逗号分隔，账号和密码间用冒号）
# GEMINIGEN_ACCOUNTS=account1@gmail.com:password1,account2@gmail.com:password2

# ── 每个账号的 Worker 线程数（默认 3）────────────────────────
WORKER_COUNT_LOCAL=3
